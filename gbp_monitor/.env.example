# Environment variables untuk GBP Monitor
# Salin file ini ke .env dan isi nilai yang sesuai
# JANGAN commit file .env ke repository!

# ── Django Core ──────────────────────────────────────────────
SECRET_KEY=ganti-dengan-secret-key-yang-aman-di-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────
# Supabase PostgreSQL (production):
# Gunakan connection string dari Settings > Database > URI di Supabase dashboard
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Development fallback (SQLite) — kosongkan DATABASE_URL atau hapus baris ini:
# DATABASE_URL=

# ── GBP API Credentials ───────────────────────────────────────
# Path ke file credentials OAuth Google (relatif dari root project atau absolut)
GBP_CREDENTIALS_PATH=data/credentials.json
GBP_TOKEN_PATH=data/token.json

# Account ID default GBP (opsional, kosongkan untuk semua akun)
GBP_DEFAULT_ACCOUNT_ID=
